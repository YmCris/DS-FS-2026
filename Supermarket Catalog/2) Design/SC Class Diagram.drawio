        <mxCell id="ZWvJ5mwmSv8HmrMkjbtI-7" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;span&gt;&lt;span&gt;supermarket&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(234, 236, 240);&quot;&gt;-&lt;/span&gt;&lt;span&gt;catalog&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(234, 236, 240);&quot;&gt;/&lt;/span&gt;&lt;span&gt;&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;├── include&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(234, 236, 240);&quot;&gt;/&lt;/span&gt;&lt;span&gt;&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│   └── catalog&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(234, 236, 240);&quot;&gt;/&lt;/span&gt;&lt;span&gt;&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── product&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── i_repository&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── avl_tree&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── hash_table&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── b_tree&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── bplus_tree&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#