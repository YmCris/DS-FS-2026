          </mxCell>
        </UserObject>
        <mxCell id="Ii5NxOn8GdtJ_dn3Qga7-10" parent="1" style="text;whiteSpace=wrap;" value="// Clases → PascalCase&#xa;class CatalogManager {};&#xa;&#xa;&#xa;// Métodos y funciones → camelCase&#xa;void insertProduct();&#xa;&#xa;&#xa;// Variables → snake_case&#xa;int product_count;&#xa;&#xa;&#xa;// Constantes y macros → SCREAMING_SNAKE&#xa;const int MAX_LOAD_FACTOR = 2;&#xa;&#xa;&#xa;// Templates → T, Key, Value (una letra o PascalCase)&#xa;template&lt;typename Key, typename Value&gt;&#xa;&#xa;&#xa;// Archivos de config → todo minúsculas&#xa;// .clang-format, .gitignore, makefile" vertex="1">
          <mxGeometry height="340" width="320" x="800" y="1480" as="geometry" />
        </mxCell>
        <mxCell id="Ii5NxOn8GdtJ_dn3Qga7-11" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;span&gt;&lt;span&gt;supermarket&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(234, 236, 240);&quot;&gt;-&lt;/span&gt;&lt;span&gt;catalog&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(234, 236, 240);&quot;&gt;/&lt;/span&gt;&lt;span&gt;&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;├── include&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(234, 236, 240);&quot;&gt;/&lt;/span&gt;&lt;span&gt;&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│   └── catalog&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(234, 236, 240);&quot;&gt;/&lt;/span&gt;&lt;span&gt;&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── product&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── i_repository&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── avl_tree&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── hash_table&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── b_tree&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── bplus_tree&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── linked_list&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── catalog_manager&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── csv_loader&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── dot_exporter&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       ├── benchmark_engine&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│       └── logger&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;h&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;├── src&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(234, 236, 240);&quot;&gt;/&lt;/span&gt;&lt;span&gt;&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│   ├── catalog_manager&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;cpp&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│   ├── csv_loader&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;cpp&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│   ├── dot_exporter&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;cpp&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│   ├── benchmark_engine&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;cpp&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│   ├── logger&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;cpp&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│   └── main&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;cpp&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;├── data&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(234, 236, 240);&quot;&gt;/&lt;/span&gt;&lt;span&gt;&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│   └── catalog&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;csv&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;├── docs&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(234, 236, 240);&quot;&gt;/&lt;/span&gt;&lt;span&gt;&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;│   └── report&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;pdf&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;├── Makefile&#xa;&lt;/span&gt;&lt;span&gt;&lt;span&gt;└── README&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;color: rgb(211, 215, 222);&quot;&gt;.&lt;/span&gt;&lt;span&gt;md&lt;/span&gt;&lt;/span&gt;" vertex="1">
