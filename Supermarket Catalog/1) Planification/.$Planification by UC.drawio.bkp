        <UserObject label="project/&#xa;├── include/          # Headers públicos (API expuesta)&#xa;│   └── project/      # Subdirectorio con el nombre del proyecto&#xa;│       └── catalog_manager.h&#xa;├── src/              # Implementaciones .cpp&#xa;├── tests/            # Unit tests (GoogleTest, Catch2)&#xa;├── docs/             # Documentación técnica&#xa;├── data/             # CSVs, assets estáticos&#xa;├── build/            # Generado, nunca en git&#xa;├── third_party/      # Dependencias externas&#xa;├── scripts/          # Scripts de automatización&#xa;├── CMakeLists.txt&#xa;├── Makefile&#xa;└── README.md" link="project/&#xa;├── include/          # Headers públicos (API expuesta)&#xa;│   └── project/      # Subdirectorio con el nombre del proyecto&#xa;│       └── catalog_manager.h&#xa;├── src/              # Implementaciones .cpp&#xa;├── tests/            # Unit tests (GoogleTest, Catch2)&#xa;├── docs/             # Documentación técnica&#xa;├── data/             # CSVs, assets estáticos&#xa;├── build/            # Generado, nunca en git&#xa;├── third_party/      # Dependencias externas&#xa;├── scripts/          # Scripts de automatización&#xa;├── CMakeLists.txt&#xa;├── Makefile&#xa;└── README.md" id="Ii5NxOn8GdtJ_dn3Qga7-8">
