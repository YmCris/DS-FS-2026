        <mxCell id="vzYu5L4vtbDAGKR6IKn7-70" parent="WIyWlLk6GJQsqaUBKTNV-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;PREVIO A JUGAR&lt;/div&gt;1.&amp;nbsp; Define la cantidad de jugadores&lt;div&gt;2.&amp;nbsp; Define el juego (Normal o flip)&lt;/div&gt;&lt;div&gt;3.&amp;nbsp; Define las reglas del juego&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;div&gt;DURANTE EL JUEGO&lt;/div&gt;&lt;div&gt;1. Crear y añadir a los jugadores&lt;/div&gt;&lt;div&gt;2. Se barajean las cartas&lt;/div&gt;&lt;div&gt;3. Se apilan las cartas&lt;/div&gt;&lt;div&gt;-&amp;gt; 4. Se reparten las cartas a los jugadores&lt;/div&gt;&lt;div&gt;5. Se deja el mazo principal&lt;/div&gt;&lt;div&gt;5. Se deja la pila de descarte&lt;/div&gt;&lt;div&gt;5. Se define el jugador inicial&lt;/div&gt;&lt;div&gt;6. Se define la rotación del juego&lt;/div&gt;&lt;div&gt;7. Juega el jugador&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;OPCIONES JUGADOR&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;0. Ver cartas propias&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;0. Ver carta en turno (junto con toda la pila de descarte)&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;0. Ver mazo principal&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;1. Poner carta&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;2. Retar&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;3. Decir &quot;UNO&quot;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;4. Report&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;DESPUÉS DEL JUEGO&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="410" width="310" x="150" y="-3451.5" as="geometry" />
        </mxCell>
