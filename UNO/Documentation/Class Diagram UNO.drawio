        <mxCell id="zAUnNzCMhgMbBxr9FVIr-73" parent="zAUnNzCMhgMbBxr9FVIr-72" style="text;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=12;whiteSpace=wrap;html=1;fillColor=#f9f7ed;strokeColor=#36393d;gradientColor=#FFE6CC;fontFamily=Times New Roman;shadow=1;" value="&lt;div&gt;&lt;span style=&quot;font-size: 14px; background-color: initial;&quot;&gt;No. de elementos relacionados&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 14px; background-color: initial;&quot;&gt;1 &lt;i&gt;no más de uno&lt;/i&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 14px; background-color: initial;&quot;&gt;&lt;i&gt;0..1 Cero o uno&lt;/i&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 14px; background-color: initial;&quot;&gt;&lt;i&gt;0...* Cero o muchos&lt;/i&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 14px; background-color: initial;&quot;&gt;&lt;i&gt;1...* Uno o muchos&lt;/i&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 14px; background-color: initial;&quot;&gt;&lt;i&gt;* Muchos&lt;/i&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
